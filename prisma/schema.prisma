generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Preserve existing table from clearsign product — do not remove
model Scan {
  id             String    @id @default(uuid())
  url            String
  scannedAt      DateTime  @default(now())
  crawledPages   String[]
  findings       Json
  score          Int
  categoryScores Json
  certified      Boolean   @default(false)
  certifiedUntil DateTime?
  status         String    @default("pending")
  error          String?
  source         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WaitlistEntry {
  id          String   @id @default(uuid())
  email       String
  name        String
  company     String?
  role        String
  companySize String?
  concern     String?
  audience    String?
  plan        String?
  source      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())
}
